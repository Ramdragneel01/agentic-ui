{
    "name": "agentic-ui",
    "version": "0.1.0",
    "description": "React component library for AI agent interfaces",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Ramdragneel01/agentic-ui.git"
    },
    "bugs": {
        "url": "https://github.com/Ramdragneel01/agentic-ui/issues"
    },
    "homepage": "https://github.com/Ramdragneel01/agentic-ui#readme",
    "engines": {
        "node": ">=20"
    },
    "main": "dist/index.cjs",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./styles.css": "./dist/styles.css"
    },
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    },
    "sideEffects": [
        "dist/styles.css"
    ],
    "scripts": {
        "clean": "rimraf dist storybook-static",
        "typecheck": "tsc --noEmit",
        "test": "vitest",
        "test:ci": "vitest run --coverage",
        "build": "tsup && npm run build:styles",
        "build:styles": "node scripts/copy-styles.mjs",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "prepublishOnly": "npm run typecheck && npm run test:ci && npm run build"
    },
    "keywords": [
        "react",
        "agents",
        "llm",
        "components",
        "storybook"
    ],
    "license": "MIT",
    "peerDependencies": {
        "react": ">=18",
        "react-dom": ">=18"
    },
    "devDependencies": {
        "@storybook/addon-a11y": "^8.6.14",
        "@storybook/addon-essentials": "^8.6.14",
        "@storybook/react-vite": "^8.6.14",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.1.0",
        "@types/node": "^22.13.5",
        "@types/react": "^18.3.17",
        "@types/react-dom": "^18.3.5",
        "@vitest/coverage-v8": "^2.1.8",
        "jsdom": "^25.0.1",
        "rimraf": "^6.0.1",
        "storybook": "^8.6.14",
        "tsup": "^8.3.5",
        "typescript": "^5.7.3",
        "vite": "^6.0.11",
        "vitest": "^2.1.8"
    }
}